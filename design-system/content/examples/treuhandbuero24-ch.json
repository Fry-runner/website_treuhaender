  "services": {
    "eyebrow": "Leistungen",
    "heading": "Alles aus einer Hand.",
    "items": [
      {
        "title": "Buchhaltung",
        "summary": "Externe Buchführung für Selbstständige und KMU – die laufenden Zahlen übernimmt ein Profi aus Ihrer Region.",
        "body": "Sie brauchen Hilfe bei Ihrer Buchhaltung? Wir übernehmen die externe Buchführung für Selbstständige und Unternehmen und halten Ihre Zahlen laufend aktuell. So überlassen Sie die Zahlen-Schieberei einem Profi aus Ihrer Region und gewinnen Zeit für Ihr Kerngeschäft. Auf Wunsch erstellen wir auch gleich Ihre Steuererklärung – mit Blick auf mögliche Optimierungen.",
        "image": "/images/treuhandbuero24-ch/pool/stock-documents-13431445.jpg"
      },
      {
        "title": "Steuerberatung",
        "summary": "Steuererklärung und Steuerberatung von einem Steuerberater aus Ihrer Region – persönlich und unverbindlich.",
        "body": "Sie suchen Unterstützung bei Steuererklärung und Steuerberatung? Bei uns sind Sie richtig. Wir kennen die Optimierungsmöglichkeiten und helfen Ihnen, davon zu profitieren – damit Sie nicht mehr Steuern zahlen als nötig. Gerade im Bereich Immobilien lässt sich mit der richtigen Planung viel erreichen. Fragen Sie unverbindlich an, wir beraten Sie persönlich.",
        "image": "/images/treuhandbuero24-ch/pool/stock-documents-7821684.jpg"
      },
      {
        "title": "Lohnadministration",
        "summary": "Lohnbuchhaltung, Sozialversicherungen und Personaladministration – zuverlässig abgewickelt.",
        "body": "Wir übernehmen Ihre Lohnadministration vollständig und termingerecht – von der Lohnabrechnung über die Sozialversicherungen bis zu den Jahresendarbeiten. Digital, transparent und persönlich betreut, damit Ihre Mitarbeitenden korrekt entlöhnt sind und Sie Zeit für Ihr Kerngeschäft gewinnen.",
        "image": "/images/treuhandbuero24-ch/pool/stock-documents-8478387.jpg"
      },
      {
        "title": "Jahresabschluss",
        "summary": "Jahresrechnung nach OR – prüfungssicher und termingerecht aufbereitet.",
        "body": "Wir erstellen Ihren Jahresabschluss vollständig und termingerecht – mit Bilanz, Erfolgsrechnung und Anhang nach Obligationenrecht. Digital, transparent und persönlich betreut, damit Ihnen ein belastbarer Abschluss als Grundlage für Steuern, Finanzierung und Planung vorliegt.",
        "image": "/images/treuhandbuero24-ch/pool/stock-office-159839.jpg"
      },
      {
        "title": "Unternehmensberatung",
        "summary": "Gründung, Budgetierung, Nachfolge und betriebswirtschaftliche Beratung.",
        "body": "Ob Gründung, Wachstum oder Nachfolge – unternehmerische Entscheidungen haben langfristige Folgen. Wir begleiten Sie mit betriebswirtschaftlichem Rat: bei der Wahl der Rechtsform, der Budget- und Liquiditätsplanung sowie bei Finanzierungs- und Investitionsfragen. So entscheiden Sie fundiert und nutzen Chancen rechtzeitig.",
        "image": "/images/treuhandbuero24-ch/pool/stock-desk-7821540.jpg"
      }
    ]
  },
