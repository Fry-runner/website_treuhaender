# Kopiere diese Datei nach  design-system/.env  (gitignored) und trage die Werte ein.
# .env wird von scripts/publish.mjs (Deploy) und scripts/send-mail.mjs (Versand) gelesen.

# --- Vercel-Deploy (ein Projekt für alle Prototypen) ---
VERCEL_TOKEN=
# optional:
VERCEL_PROJECT_NAME=treuhand-prototypes
# VERCEL_TEAM_ID=

# --- E-Mail-Versand über deine ETH-Mailbox (Microsoft 365 / Exchange Online) ---
# Hinweis: M365 hat SMTP-AUTH oft deaktiviert + ETH erzwingt MFA. Falls der Versand
# mit 535/"SMTP AUTH disabled" scheitert: ETH-IT bitten, "Authenticated SMTP" für
# dein Postfach zu aktivieren, oder ein App-/Geräte-Passwort verwenden.
ETH_SMTP_USER=                       # i.d.R. deine volle ETH-Adresse (Login)
ETH_SMTP_PASS=                       # ETH-Passwort oder App-/Geräte-Passwort
# optional:
ETH_SMTP_FROM=                       # Absenderadresse (Default = ETH_SMTP_USER)
ETH_SMTP_HOST=smtp.office365.com     # Default; nur ändern, wenn ETH einen eigenen Relay nennt
ETH_SMTP_PORT=587                    # 587 = STARTTLS (Default), 465 = SSL
ETH_SMTP_REPLYTO=                    # z.B. oliver@fam-glaeser.de (Antworten landen dort)
